# App
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kavita
DB_CONNECTION_LIMIT=10
DB_WAIT_FOR_CONNECTIONS=true
DB_MAX_IDLE=10
DB_IDLE_TIMEOUT=60000
DB_ENABLE_KEEP_ALIVE=true
DB_KEEP_ALIVE_DELAY=0

# Storage
STORAGE_DRIVER=local
STORAGE_CDN_URL=
UPLOAD_MAX_FILE_SIZE=5242880

# AWS S3 (preencha ao usar STORAGE_DRIVER=s3)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Google Cloud Storage (preencha ao usar STORAGE_DRIVER=gcs)
GCP_PROJECT_ID=
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Secrets rotation
SECRETS_MANAGER_SECRET_ID=
DB_ADMIN_USER=
DB_ADMIN_PASSWORD=
DB_USER_HOST=%
UPDATE_ENV_FILE=false
ENV_FILE_PATH=.env
