# ======================================
# AMBIENTE
# ======================================

NODE_ENV=development
PORT=5000

# ======================================
# BANCO DE DADOS
# ======================================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=seu_usuario
DB_PASSWORD=CHANGE_ME
DB_NAME=kavita
DB_NAME_TEST=kavita_test

# ======================================
# AUTENTICAÇÃO (JWT)
# ======================================

# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_32_chars

# Criptografia de CPF em repouso (LGPD). Obrigatória em produção.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Sem essa variável, CPFs ficam em plaintext (aceitável apenas em dev local).
CPF_ENCRYPTION_KEY=

# ======================================
# EMAIL / SMTP
# ======================================
#
# Arquitetura do envio de e-mail (services/mail/transport.js):
#
#   MAIL_PROVIDER define o modo de envio. Ordem de decisão:
#     1. MAIL_PROVIDER explícito (recomendado em produção)
#     2. Autodiscovery: SENDGRID_API_KEY > SMTP_HOST > EMAIL_USER (Gmail legado)
#     3. Nada: erro em produção / stub em dev
#
#   Valores aceitos de MAIL_PROVIDER:
#     - sendgrid  → usa SENDGRID_API_KEY via relay SMTP do SendGrid (recomendado)
#     - smtp      → usa SMTP_HOST/SMTP_PORT/SMTP_USER/SMTP_PASS/SMTP_SECURE
#     - disabled  → não envia nada, só loga (ÚTIL EM DEV; BLOQUEADO EM PROD)
#
#   Endereço remetente (From):
#     - MAIL_FROM      → preferido ("no-reply@kavita.com.br")
#     - SMTP_FROM      → legado ("Kavita <no-reply@...>" também aceito)
#     - EMAIL_USER     → fallback pro legado Gmail
#     O nome contextual de cada e-mail ("Curadoria Kavita", "Kavita — Segurança",
#     etc.) é definido no código; o endereço sempre vem destas vars.

# Escolha do provider. Em produção, não aceite "disabled" ou vazio.
MAIL_PROVIDER=disabled

# Endereço remetente único. Usado em TODOS os e-mails do sistema.
MAIL_FROM=no-reply@seudominio.com
MAIL_FROM_NAME=Kavita

# --- SendGrid (recomendado em produção) ---
# Como obter: https://app.sendgrid.com/settings/api_keys
# Plano gratuito: 100 e-mails/dia, sem cartão. Domínio remetente precisa
# ser verificado em https://app.sendgrid.com/settings/sender_auth antes
# do primeiro envio.
SENDGRID_API_KEY=

# --- SMTP genérico (AWS SES, Mailgun, Postmark, SMTP corporativo) ---
# Usado quando MAIL_PROVIDER=smtp. Deixe vazio se for usar SendGrid.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# SMTP_FROM: legado — novo código usa MAIL_FROM. Mantido por compat.
SMTP_FROM=

# --- Gmail legado (APENAS dev local) ---
# Funciona mas a senha de app expira com frequência. Não use em produção.
EMAIL_USER=CHANGE_ME@seudominio.com
EMAIL_PASS=CHANGE_ME_app_password

# ======================================
# MERCADO PAGO
# ======================================

# Use token de SANDBOX em desenvolvimento (nunca o token de produção aqui)
MP_ACCESS_TOKEN=CHANGE_ME_use_sandbox_token_in_dev

# Segredo HMAC-SHA256 para validar assinaturas de webhook do Mercado Pago.
# OBRIGATÓRIO em produção: sem ele o servidor recusa o startup (env.js bloqueia).
# Em dev, ausência gera aviso mas não bloqueia. Webhook retorna 401 se ausente (fail-closed).
# Como obter: no painel MP → Suas Integrações → Webhooks → segredo da assinatura
MP_WEBHOOK_SECRET=CHANGE_ME_webhook_secret_from_mp_dashboard

# URL pública para receber notificações de webhook do Mercado Pago.
# Se definida, é enviada como notification_url na criação da Preference.
# OBRIGATÓRIA em produção desde Fase 1 do go-live: sem ela, MP cria a Preference
# mas nunca chama webhook → status_pagamento fica "pendente" para sempre.
# Em produção precisa começar com https:// (validação fail-fast no boot).
# Staging:  use a URL de staging ou um tunnel (ex: https://abc.ngrok.io/api/payment/webhook)
# Dev:      deixe em branco ou use tunnel temporário para testar o fluxo completo
MP_WEBHOOK_URL=

# ======================================
# URLs DA APLICAÇÃO
# ======================================

# URL do frontend (usada em redirects, CORS etc)
APP_URL=http://localhost:3000

# URL pública do backend
BACKEND_URL=http://localhost:5000

# URL pública do site (caso diferente do APP_URL)
PUBLIC_SITE_URL=http://localhost:3000

# ======================================
# CORS
# ======================================

# Separe múltiplas origens por vírgula
ALLOWED_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=true
CORS_EXPOSE_HEADERS=Location,Link,ETag,Request-Id

# ======================================
# TABELAS (customização opcional)
# ======================================

PRODUCTS_TABLE=products
PRODUCT_IMAGES_TABLE=product_images
PRODUCT_CATEGORY_COL=category_id
PRODUCT_IMAGE_COL=image

# ======================================
# LOGS / SEGURANÇA
# ======================================

LOG_LEVEL=info
LOG_PRETTY=true
LOG_REQUEST_BODY=false
ENABLE_HELMET=true

# ======================================
# WEBHOOK RETRY JOB (Fase 1 go-live — B6)
# ======================================
# Reprocessa eventos webhook MP em estado PARKED:PENDING_ORDER_MATCH:*
# (cliente pagou, mas pedido ainda não existia ou foi cancelado entre
# /payment/start e o webhook). Sem este job, esses eventos ficam
# pendurados para sempre — pedido nunca vira "pago".
#
# Default DESLIGADO; ligar em produção:
WEBHOOK_RETRY_JOB_ENABLED=false
# Intervalo entre execuções (ms). Mínimo aceito: 30000 (30s).
WEBHOOK_RETRY_JOB_INTERVAL_MS=60000
# Eventos por tick. Default 50, máx 500.
WEBHOOK_RETRY_JOB_BATCH=50
# Após esse retry_count, evento é marcado RETRY_EXHAUSTED + alerta Sentry.
# Default 288 = ~24h em janelas de 5min (jobs/ticks intercalados).
WEBHOOK_RETRY_JOB_MAX_ATTEMPTS=288

# ======================================
# RATE LIMITS ABSOLUTOS POR IP (Fase 1 go-live — B5)
# ======================================
# Limites por IP por minuto (override do default). Valores devem ser
# inteiros positivos; ausência = default.
#
# RATE_LIMIT_GLOBAL_PER_MINUTE=300         # global
# RATE_LIMIT_WEBHOOK_PER_MINUTE=60         # /webhooks/* (MP, Asaas, ClickSign)
# RATE_LIMIT_CHECKOUT_PER_MINUTE=10        # /checkout (chave por userId quando logado)
# RATE_LIMIT_LOGIN_PER_MINUTE=10           # /login, /admin/login, /corretora/login
# RATE_LIMIT_MOTORISTA_MAGIC_PER_MINUTE=5  # /motorista/magic-link
# RATE_LIMIT_PRODUCER_MAGIC_PER_MINUTE=5   # /produtor/magic-link
# RATE_LIMIT_REGISTER_PER_MINUTE=3         # /users/register

# ======================================
# OBSERVABILIDADE — SENTRY
# ======================================
#
# Error tracking em produção. A integração (lib/sentry.js) é opt-in:
# ausência de SENTRY_DSN deixa tudo como no-op (nada quebra em dev).
#
# Como configurar:
#   1. Criar projeto em https://sentry.io (plano Developer free: 5k
#      eventos/mês + 1 user + 30 dias de retenção).
#   2. Selecionar plataforma "Node.js" / "Express".
#   3. Copiar o DSN (fica em Settings → Client Keys (DSN)).
#   4. Setar aqui: SENTRY_DSN=https://xxx@oNNN.ingest.us.sentry.io/NNN
#   5. Deploy. O middleware de erro (middleware/errorHandler.js) já
#      captura 5xx automaticamente; 4xx são filtrados em beforeSend.
#
# Amostragem de performance tracing (opcional): 0.0-1.0.
# 0.1 = 10% das requests geram transação APM. Começa em 0.1 em prod.
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1

# ======================================
# BACKUP DE BANCO DE DADOS
# ======================================
#
# scripts/backup-mysql.js faz dump gzipped da base e opcionalmente
# envia pra S3/R2 (se STORAGE_PROVIDER estiver configurado).
#
# Local: backups/kavita-YYYY-MM-DD-HHMMSS.sql.gz
# Retenção: BACKUP_RETENTION_DAYS (default 30).
#
# Para rodar manual:
#   npm run db:backup
#
# Para cron diário (Linux):
#   0 3 * * * cd /var/app/kavita-backend && /usr/bin/node scripts/backup-mysql.js >> /var/log/kavita-backup.log 2>&1
#
# Para Task Scheduler (Windows): ver docs/backup-restore.md
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
# Caminho do mysqldump (opcional). Default: procura no PATH.
# Windows típico: C:\Program Files\MySQL\MySQL Server 8.0\bin\mysqldump.exe
MYSQLDUMP_PATH=

# ======================================
# NOTIFICAÇÕES / WORKERS
# ======================================

DISABLE_NOTIFICATIONS=false
ABANDON_NOTIF_WORKER_INTERVAL_SECONDS=10
ABANDON_CART_WORKER_INTERVAL_MS=60000
ABANDON_CART_WORKER_BATCH_LIMIT=50
ABANDON_CART_HOURS=24

# ---- Scan automatico de carrinhos abandonados (novo em 2026-04-22) ----
# Promove carrinhos abertos com idade > ABANDONED_CART_MIN_HOURS para
# carrinhos_abandonados. Sem este job, o /admin/carrinhos fica vazio.
ABANDONED_CART_SCAN_ENABLED=true
ABANDONED_CART_SCAN_INTERVAL_MS=900000
ABANDONED_CART_MIN_HOURS=24

# ======================================
# LEADS PARADOS — SAAS CORRETORAS (G2)
# ======================================
# Cron diario que cria notificacao no painel da corretora quando ha
# leads aguardando primeiro contato ha tempo demais. Anti-spam: 1
# alerta por corretora por dia maximo.
#
# Regra (conservadora na primeira versao):
#   status='new' AND first_response_at IS NULL
#   AND created_at < NOW() - STALE_LEADS_THRESHOLD_HOURS
#
# Default DESLIGADO ate decisao consciente em prod.
STALE_LEADS_SCAN_ENABLED=false
STALE_LEADS_SCAN_CRON=0 8 * * *
STALE_LEADS_THRESHOLD_HOURS=72

# E-mail agregado diario (opcional, alem da notif no painel).
# Default: false. Ative apenas se quiser caixa de entrada da corretora.
STALE_LEADS_EMAIL_ENABLED=false

# ======================================
# MOTORISTA — magic-link e auto-envio
# ======================================
# TTL do magic-link em minutos. Default 480 (8h, cobre turno).
# Diminua para ambientes mais sensiveis (15 e' o minimo razoavel).
MOTORISTA_MAGIC_TTL_MIN=480

# Duracao da sessao apos consumir o magic-link (em horas).
MOTORISTA_SESSION_TTL_HOURS=4

# Auto-envio do magic-link via WhatsApp quando admin marca rota como
# 'pronta' ou troca o motorista de uma rota pronta. Default ON.
# Desligue (=false) caso WhatsApp esteja com problema ou admin queira
# disparo manual via botao no painel.
MOTORISTA_MAGIC_LINK_AUTO_SEND=true

# Bloqueia auto-send quando WHATSAPP_PROVIDER != api. Default OFF.
# Em modo manual, sendWhatsapp() so' gera link wa.me e devolve pra admin
# clicar — auto-send em manual nao entrega mensagem nenhuma. Com a flag
# ON, o auto-send pula e loga 'rotas.auto_magic_link.skipped_provider_manual'
# em vez de gerar a ilusao de que o motorista recebeu.
MOTORISTA_AUTO_SEND_REQUIRES_API=false

# Bloqueia POST /paradas/:id/entregue quando a parada nao tem foto NEM
# assinatura salvas. Default OFF (preserva regra Fase 5: comprovante
# opcional). Liga em prod (=true) quando a operacao decidir que entrega
# so' vale com prova material. Endereca o caso onde POST /comprovante
# falha 500 mas o frontend chama POST /entregue mesmo assim.
MOTORISTA_REQUIRE_COMPROVANTE=false

# Quando true, POST /paradas/:id/comprovante com payload vazio retorna
# 400 amigavel ('Envie ao menos uma foto OU assinatura'). Default OFF
# preserva o no-op silencioso da Fase 5 (frontend pode pular sem 4xx).
MOTORISTA_REQUIRE_COMPROVANTE_PAYLOAD=false

# ======================================
# MEDIA / UPLOAD — comportamento do diskAdapter
# ======================================
# Diretorio onde imagens/videos sao gravados. Pode ser absoluto
# (/var/kavita/uploads) ou relativo a raiz do backend. Default: 'uploads'.
# String vazia faz o servidor recusar o boot (fail-fast).
MEDIA_UPLOAD_DIR=uploads
# Prefixo publico HTTP. Tudo que persiste retorna `${MEDIA_PUBLIC_PREFIX}/...`.
MEDIA_PUBLIC_PREFIX=/uploads

# ======================================
# ROTAS ORFAS — AUTO-CANCELAMENTO (Bug 3 fluxo Pedidos<->Rotas)
# ======================================
# Cron noturno que cancela rotas em status 'em_rota' sem nenhum update
# ha mais de N horas. Cobre o caso do motorista que abandona a rota
# (perdeu o telefone, desistiu) — sem isso, paradas ficam travadas em
# 'pendente' indefinidamente e os pedidos nao retornam ao pool.
#
# Cancelamento usa rotasService.alterarStatus -> respeita FSM.
# Default DESLIGADO ate validacao do pilot operacional.
ROTAS_ORFAS_SCAN_ENABLED=false
ROTAS_ORFAS_SCAN_CRON=0 1 * * *
ROTAS_ORFAS_HORAS=24

# ======================================
# AUTO-DOWNGRADE DE TRIAL EXPIRADO (G4)
# ======================================
# Quando o trial da corretora encerra, o sistema rebaixa automaticamente
# para o plano FREE em vez de deixar a corretora "trialing" perpetuamente
# acessando features pagas.
#
# Fluxo (so' bucket 'expired' do trialReminderService):
#   1. Margem de seguranca: skip se trial_ends_at < grace
#      (evita rebaixar trial recem-expirado que admin pode estender)
#   2. Idempotencia: skip se ja existe subscription_events
#      event_type='trial_expired_downgrade' para esta subscription
#   3. Chama planService.cancelPlan (transacional, idempotente, ja
#      preserva subscription antiga como 'canceled' e cria nova FREE)
#   4. Envia e-mail "expired" com copy "FREE ativado"
#   5. Cria notificacao no painel da corretora (type='trial_expired')
#
# NAO toca em: corretora_users (login mantem), leads, contratos
# emitidos, schema. Reusa cancelPlan existente.
#
# Default DESLIGADO ate decisao consciente em prod. Quando OFF:
#   - email expired continua sendo enviado (comportamento pre-G4)
#   - copy do email cai no caminho legado generico (sem mencionar
#     FREE ativado, porque o downgrade nao aconteceu)
TRIAL_AUTO_DOWNGRADE_ENABLED=false
TRIAL_AUTO_DOWNGRADE_GRACE_HOURS=1

# ======================================
# KYC PARADO — ALERTA NO PAINEL ADMIN (G5)
# ======================================
# Cron diario que detecta corretoras com KYC parado por tempo demais
# e cria entrada de auditoria em corretora_admin_notes (category=
# 'kyc_stale_alert', admin_id=NULL). NAO altera FSM nem muta status
# da corretora — so observa + registra.
#
# Estados monitorados:
#   pending_verification: corretora cadastrou conta mas nao submeteu CNPJ
#                         (idade desde corretoras.created_at)
#   under_review:         corretora submeteu, admin nao aprovou/rejeitou
#                         (idade desde corretora_kyc.updated_at)
#
# Estados terminais (verified, rejected) ficam de fora.
#
# Anti-spam: 1 nota/corretora/dia max via DATE(created_at)=CURDATE().
#
# Default DESLIGADO ate decisao consciente em prod.
KYC_STALE_SCAN_ENABLED=false
KYC_STALE_SCAN_CRON=0 9 * * *
KYC_STALE_PENDING_DAYS=7
KYC_STALE_REVIEW_DAYS=3

# ======================================
# WHATSAPP — ENVIO DE MENSAGENS (B3)
# ======================================
#
# Arquitetura do envio (services/whatsapp/index.js):
#
#   WHATSAPP_PROVIDER decide o adapter:
#     - manual (default) → gera link wa.me e devolve pro admin clicar.
#                          Não envia nada de verdade. Funciona sem
#                          credencial nenhuma. Útil para validar conteúdo
#                          das mensagens antes de plugar Meta.
#     - api              → integração Meta WhatsApp Business Cloud API.
#                          Envia mensagem real (texto livre OU template
#                          aprovado). Exige credenciais + templates
#                          aprovados pela Meta para funcionar fora da
#                          janela de 24h.
#
# IMPORTANTE: deixe em "manual" até ter:
#   1. Conta WhatsApp Business + número verificado na Meta.
#   2. Pelo menos 1 template UTILITY aprovado (ex: pedido_recebido_v1).
#   3. Variáveis WHATSAPP_TEMPLATE_* setadas com o nome exato aprovado.
#
# Sem isso, modo "api" tenta texto livre, Meta rejeita fora da janela
# 24h, comunicação falha silenciosamente (vai pro log, status='falha').

WHATSAPP_PROVIDER=manual

# --- Credenciais Meta Cloud API ---
# Como obter: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
#   1. Criar app em developers.facebook.com → produto WhatsApp.
#   2. Adicionar/verificar número de telefone.
#   3. Em "API Setup" copiar:
#        - Phone number ID (vai em WHATSAPP_PHONE_NUMBER_ID)
#        - Permanent token (vai em WHATSAPP_API_TOKEN — NUNCA o token
#          temporário de 24h). Gerar System User token no Business Manager.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Versão da API Graph (default v22.0). Subir conforme Meta deprecia versões.
WHATSAPP_API_VERSION=v22.0

# Timeout em ms para chamadas à Meta. Default 8s.
WHATSAPP_API_TIMEOUT_MS=8000

# --- Templates aprovados pela Meta ---
# Cada evento de pedido aponta para 1 template UTILITY aprovado. Sem env
# setada, a comunicação correspondente CAI no modo texto livre, que a
# Meta rejeita fora da janela de 24h. Ative só os eventos para os quais
# já tenha template aprovado.
#
# Convenção (ver services/whatsapp/templateMap.js para o body esperado):
#   pedido_criado          → params [firstName, pedidoId, totalBR]
#   pagamento_aprovado     → params [firstName, pedidoId]
#   pedido_em_separacao    → params [firstName, pedidoId]
#   pedido_enviado         → params [firstName, pedidoId]
#   pedido_entregue        → params [firstName, pedidoId]
#   pedido_cancelado       → params [firstName, pedidoId]
#
# Carrinho abandonado (MARKETING) NÃO entra nesta lista — segue manual
# até aprovação dedicada da Meta + opt-in real do cliente.
WHATSAPP_TEMPLATE_PEDIDO_CRIADO=
WHATSAPP_TEMPLATE_PAGAMENTO_APROVADO=
WHATSAPP_TEMPLATE_PEDIDO_EM_SEPARACAO=
WHATSAPP_TEMPLATE_PEDIDO_ENVIADO=
WHATSAPP_TEMPLATE_PEDIDO_ENTREGUE=
WHATSAPP_TEMPLATE_PEDIDO_CANCELADO=

# Idioma dos templates aprovados. Default pt_BR.
WHATSAPP_TEMPLATE_LANG=pt_BR

# ======================================
# CLIMA (sync automático)
# ======================================

# Habilita sync automatico de dados de chuva (Open-Meteo)
CLIMA_SYNC_ENABLED=false

# Expressao cron (default: a cada 3h). Exemplos:
#   "0 */3 * * *"  → a cada 3h (default)
#   "0 */6 * * *"  → a cada 6h
#   "30 5,11,17 * * *" → 05:30, 11:30, 17:30
CLIMA_SYNC_CRON=0 */3 * * *

# Delay em ms entre requisicoes por cidade (rate limiting para Open-Meteo free tier)
CLIMA_SYNC_DELAY_MS=1500

# ======================================
# COTAÇÕES
# ======================================

# Habilita providers externos de cotações (BCB PTAX, Stooq).
# Sem isso, sync manual e automático retornam PROVIDER_DISABLED.
COTACOES_PROVIDER_ENABLED=true

# Habilita sync automático de cotações via cron
COTACOES_SYNC_ENABLED=false

# Expressão cron (default: a cada 4h). Exemplos:
#   "0 */4 * * *"  → a cada 4h (default)
#   "0 */2 * * *"  → a cada 2h
#   "0 8,12,18 * * *" → 08:00, 12:00, 18:00
#   "0 9-18 * * 1-5" → de hora em hora, seg-sex, 9h-18h
COTACOES_SYNC_CRON=0 */4 * * *

# ======================================
# CONTRATOS (Fase 10.1)
# ======================================

# Provedor de assinatura digital.
#   stub       → assinatura simulada em dev/staging, sem gastar tokens
#                ATENÇÃO: BLOQUEADO em NODE_ENV=production (Fase 1 go-live).
#                Servidor recusa boot se prod=stub. Stub gera contratos com
#                signer_document_id="stub-<uuid>" sem validade jurídica.
#   clicksign  → integração real. OBRIGATÓRIO em produção. Requer também
#                CLICKSIGN_API_TOKEN e CLICKSIGN_HMAC_SECRET preenchidos.
CONTRATO_SIGNER_PROVIDER=stub

# ClickSign — credenciais da API v3. Em sandbox, URL é clicksign
# sandbox; em prod, app.clicksign.com.
#   Crie um token em Configurações → API Access
#   Crie um webhook em Configurações → Webhooks apontando para
#   APP_URL/api/webhooks/clicksign com segredo HMAC.
CLICKSIGN_API_TOKEN=
CLICKSIGN_API_URL=https://sandbox.clicksign.com
CLICKSIGN_HMAC_SECRET=

# ======================================
# COTAÇÕES / MARKET DATA (Fase 10.4)
# ======================================

# Ativa o cron de sincronização de snapshots de cotação (CEPEA +
# ICE "C"). Sem isso, o endpoint /api/public/market-quotes/current
# devolve null até que algum cron rode manualmente.
MARKET_QUOTES_SYNC_ENABLED=false

# Cron padrão: 18h (America/Sao_Paulo) em dias úteis, pós-fechamento
# CEPEA (publica até 17h). Alterar conforme necessidade operacional.
MARKET_QUOTES_SYNC_CRON=0 18 * * 1-5

# Provider do CEPEA. O adapter "noticias_agricolas" faz scraping da
# página pública do site de notícias. Validar ToS antes de ligar em
# produção.
COTACAO_CAFE_PROVIDER=noticias_agricolas

# Desliga o adapter ICE (Stooq) caso a fonte pare de responder. Em
# operação normal, deixar vazio ou "false".
ICE_COFFEE_PROVIDER_DISABLED=false
# ======================================
# LGPD / PRIVACIDADE (Fase 10.3)
# ======================================

# Janela de arrependimento para exclusão de conta. Padrão 30 dias.
PRIVACY_DELETION_GRACE_DAYS=30
