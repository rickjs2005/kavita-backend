# =========================
# CLAUDE CODE (config local)
# =========================
.claude/

# =========================
# ENV / SECRETS (NUNCA COMMITAR)
# =========================
.env
.env.local
.env.development
.env.production
.env.test
.env.staging
.env.*.local
.env.*.backup
.env.*.bak
.env.*.tmp
.env.*.swp

# Permitir versionar exemplo (sem segredos)
!.env.example

# Certificados / chaves privadas — NUNCA commitar
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
secrets/
credentials/
serviceAccount*.json
gcp-key*.json

# =========================
# DEPENDÊNCIAS
# =========================
node_modules/

# =========================
# LOGS / DEBUG
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================
# TESTES / COVERAGE
# =========================
coverage/
.nyc_output/

# =========================
# BUILD / OUTPUT
# =========================
dist/
build/
out/

# =========================
# CACHE / TEMP
# =========================
.tmp/
temp/
.cache/
.turbo/
.eslintcache
*.tsbuildinfo

# =========================
# RUNTIME / PID
# =========================
pids/
*.pid
*.seed
*.pid.lock

# =========================
# UPLOADS / ARQUIVOS LOCAIS
# (Se sua app salva arquivos em disco localmente, ignore)
# =========================
uploads/
public/uploads/
# Arquivos privados (contratos assinados, etc.). Servidos somente
# via rotas autenticadas, nunca expostos via express.static.
storage/

# =========================
# BACKUPS / DUMPS DE BANCO (scripts/backup-mysql.js)
# =========================
backups/
*.sql.gz
*.sql.bak
*.sql.dump
*.dump
*.dump.gz

# Banco local SQLite (caso seja usado em algum cenario de dev)
*.sqlite
*.sqlite3
*.db
*.db-journal

# =========================
# IDE / OS
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =========================
# DOCKER (opcional: se gerar local)
# =========================
*.local.yml
