{
  "name": "backend",
  "version": "1.0.0",
  "description": "API backend do projeto Kavita com testes automatizados",
  "main": "server.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:cov": "cross-env NODE_ENV=test jest --coverage"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.12.0",
    "nodemailer": "^6.10.0",
    "slugify": "^1.6.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "typescript": "^5.7.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.1",
    "@types/jest": "^29.5.12",
    "cross-env": "^7.0.3"
  },
  "jest": {
  "testEnvironment": "node",
  "roots": ["<rootDir>"],
  "testMatch": [
    "**/unit/**/*.test.js",
    "**/integration/**/*.test.js"
  ],
  "setupFiles": ["<rootDir>/teste/setup/env.setup.js"],
  "setupFilesAfterEnv": ["<rootDir>/teste/setup/jest.setup.js"],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/$1"
  },
  "collectCoverageFrom": [
    "routes/**/*.js",
    "controllers/**/*.js",
    "services/**/*.js",
    "server.js"
  ]
},
  "keywords": []
}
