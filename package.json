{
  "name": "backend",
  "version": "1.0.0",
  "description": "API backend do projeto Kavita com testes automatizados",
  "main": "server.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node scripts/run-jest.js --runInBand",
    "test:watch": "node scripts/run-jest.js --watch",
    "test:cov": "node scripts/run-nyc.js -- --runInBand"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.12.0",
    "nodemailer": "^6.10.0",
    "slugify": "^1.6.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.1",
    "typescript": "^5.7.3"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>"
    ],
    "testMatch": [
      "**/unit/**/*.test.js",
      "**/integration/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/teste/setup/env.setup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/teste/setup/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "transform": {},
    "coverageProvider": "v8",
    "collectCoverageFrom": [
      "controllers/authController.js",
      "routes/login.js",
      "routes/checkoutRoutes.js",
      "routes/payment.js",
      "routes/adminProdutos.js",
      "middleware/verifyAdmin.js",
      "services/mailService.js",
      "utils/passwords.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 55,
        "functions": 70,
        "lines": 70
      }
    }
  },
  "keywords": []
}
