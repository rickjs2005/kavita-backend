<!--
  Base layout para contratos de compra e venda de café.
  O corpo específico (disponível / entrega futura) é injetado em {{{bodyHtml}}}.
  Todos os valores sensíveis (telefone, preço) são renderizados no body —
  este layout cuida apenas de moldura, cabeçalho, rodapé e verificação.
-->
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Contrato {{metaContrato.numero_externo}}</title>
  <style>
    @page {
      size: A4;
      margin: 20mm 20mm 28mm 20mm;
    }
    html, body {
      font-family: "Times New Roman", Times, serif;
      color: #1a1a1a;
      font-size: 11.5pt;
      line-height: 1.55;
      margin: 0;
      padding: 0;
    }
    .document-header {
      border-bottom: 2px solid #2e5734;
      padding-bottom: 12px;
      margin-bottom: 24px;
    }
    .document-header .brand {
      font-size: 20pt;
      font-weight: bold;
      color: #2e5734;
      letter-spacing: 1px;
    }
    .document-header .subtitle {
      font-size: 10pt;
      color: #5a5a5a;
      margin-top: 2px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .document-header .meta {
      font-size: 9.5pt;
      color: #5a5a5a;
      margin-top: 8px;
      display: flex;
      justify-content: space-between;
    }
    h1 {
      font-size: 16pt;
      text-align: center;
      margin: 0 0 20px;
      color: #2e5734;
      letter-spacing: 0.5px;
    }
    h2.clause-title {
      font-size: 12pt;
      font-weight: bold;
      margin: 20px 0 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .parties-block {
      background: #f4f1ea;
      border-left: 3px solid #2e5734;
      padding: 12px 16px;
      margin-bottom: 20px;
      font-size: 10.5pt;
    }
    .parties-block p {
      margin: 4px 0;
    }
    .clause p {
      text-align: justify;
      margin: 6px 0;
    }
    table.spec-table {
      width: 100%;
      border-collapse: collapse;
      margin: 10px 0;
      font-size: 10.5pt;
    }
    table.spec-table th,
    table.spec-table td {
      border: 1px solid #c9c1b4;
      padding: 6px 10px;
      text-align: left;
    }
    table.spec-table th {
      background: #f4f1ea;
      font-weight: bold;
    }
    .signature-block {
      margin-top: 48px;
      display: flex;
      justify-content: space-between;
      font-size: 10.5pt;
    }
    .signature-block .party {
      width: 45%;
      border-top: 1px solid #1a1a1a;
      padding-top: 6px;
      text-align: center;
    }
    .verification {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      border-top: 1px solid #c9c1b4;
      padding: 8px 20mm;
      font-size: 8.5pt;
      color: #5a5a5a;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: white;
    }
    .verification .qr img {
      width: 56px;
      height: 56px;
      display: block;
    }
    .verification .hash {
      font-family: "Courier New", monospace;
      font-size: 7.5pt;
      word-break: break-all;
      max-width: 60%;
    }
    .verification .hash strong {
      display: block;
      font-family: "Times New Roman", serif;
      font-size: 8.5pt;
      color: #1a1a1a;
      margin-bottom: 2px;
    }
  </style>
</head>
<body>
  <div class="document-header">
    <div class="brand">KAVITA · Mercado do Café</div>
    <div class="subtitle">Instrumento Particular de Compra e Venda</div>
    <div class="meta">
      <span>Nº {{metaContrato.numero_externo}}</span>
      <span>Emitido em {{dataBR metaContrato.emitido_em}}</span>
    </div>
  </div>

  {{{bodyHtml}}}

  <div class="verification">
    <div class="qr">
      <img src="{{metaContrato.qr_data_url}}" alt="QR de verificação" />
    </div>
    <div class="hash">
      <strong>Autenticidade verificável em {{metaContrato.verify_url}}</strong>
      SHA-256 do documento (o hash completo é registrado na plataforma)
    </div>
  </div>
</body>
</html>
